{
  "name": "watson-sak",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:local": "ENVIRONMENT=local-backend react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsgo",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "unused": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "verify": "concurrently -n test,lint,format,types,unused -c green,yellow,magenta,cyan,blue \"npm run test\" \"npm run lint\" \"npm run format\" \"npm run typecheck\" \"npm run unused\""
  },
  "dependencies": {
    "@conform-to/react": "^1.19.1",
    "@conform-to/zod": "^1.19.1",
    "@grafana/faro-react": "^2.6.3",
    "@navikt/aksel-icons": "^8.6.0",
    "@navikt/ds-css": "^8.6.0",
    "@navikt/ds-react": "^8.6.0",
    "@navikt/ds-tailwind": "^8.6.0",
    "@navikt/oasis": "^4.1.0",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.5.0",
    "isbot": "^5.1.39",
    "postcss": "^8.5.10",
    "postcss-import": "^16.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-router": "^7.14.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "unleash-client": "^6.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "^7.14.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260504.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "protobufjs": "8.0.2"
  }
}
